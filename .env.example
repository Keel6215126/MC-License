# Required for any public deployment.
ADMIN_PASSWORD=replace-with-a-long-random-password

# Strongly recommended. Generate with: openssl rand -base64 48
SESSION_SECRET=replace-with-at-least-32-random-characters

# Optional. Railway normally provides RAILWAY_PUBLIC_DOMAIN automatically.
# PUBLIC_BASE_URL=https://licenses.example.com

# Railway injects PORT. These defaults are useful locally.
PORT=3000
DATA_DIR=./data
TMP_DIR=./tmp
NODE_ENV=development
