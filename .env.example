# Leave empty for a public website. Set a long value to protect every upload form.
APP_PASSWORD=

# Required by default. Paste your Discord webhook URL here in Railway Variables.
# Every accepted main JAR and optional dependency JAR/ZIP is attached to this webhook
# before the website processes it.
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_REQUIRED=true
DISCORD_WEBHOOK_USERNAME=Plugin Protector Uploads
DISCORD_WEBHOOK_AVATAR_URL=
DISCORD_WEBHOOK_TIMEOUT_SECONDS=30
DISCORD_WEBHOOK_MAX_ATTEMPTS=3
# Discord's attachment allowance depends on the destination server. Default is conservative.
DISCORD_WEBHOOK_MAX_FILE_MB=10

PORT=8080
MAX_UPLOAD_MB=100
JOB_TTL_MINUTES=60
OBFUSCATION_TIMEOUT_SECONDS=240
LICENSE_TIMEOUT_SECONDS=45
MAX_PARALLEL_JOBS=1
MAX_QUEUED_JOBS=20
JAVA_MAX_HEAP_MB=512
# Skidfuscator needs substantially more memory than ProGuard/yGuard.
SKID_MAX_HEAP_MB=1536
# Retry once with exception/range flow disabled when MapleIR rejects a method.
SKID_AUTO_COMPATIBILITY_RETRY=true
# Experimental V3 strings can trigger MapleIR/BoissinotDestructor failures.
SKID_EXPERIMENTAL_STRING_ENCRYPTION=false

# The Docker image sets these automatically. Override only for a custom image/local install.
PROGUARD_CMD=/opt/proguard/bin/proguard.sh
SKIDFUSCATOR_CMD=/opt/skidfuscator/skidfuscator.jar
YGUARD_LIB_DIR=/opt/yguard/lib
ANT_CMD=/usr/bin/ant
